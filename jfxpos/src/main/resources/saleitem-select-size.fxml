<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" stylesheets="@.root.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label maxWidth="1.7976931348623157E308" style="-fx-font-size: 1.8em; -fx-font-weight: bold;" text="Select Size">
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>
      <TableView fx:id="sizeTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colSize" prefWidth="180.0" text="Size" />
          <TableColumn fx:id="colColor" prefWidth="180.0" text="Color" />
          <TableColumn fx:id="colArticle" prefWidth="180.0" text="Article" />
        </columns>
      </TableView>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button fx:id="btnSelect" minWidth="-Infinity" mnemonicParsing="false" prefWidth="100.0" text="Select" />
            <Button fx:id="btnCancel" minWidth="-Infinity" mnemonicParsing="false" prefWidth="100.0" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="20.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="30.0" left="20.0" right="20.0" top="10.0" />
   </padding>
</VBox>
