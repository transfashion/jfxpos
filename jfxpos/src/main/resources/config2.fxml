                              <TextField fx:id="txtTicketPrinter" GridPane.columnIndex="1" GridPane.columnSpan="4" GridPane.rowIndex="7" />
                              <Button mnemonicParsing="false" text="Test Print" GridPane.columnIndex="5" GridPane.rowIndex="7" />
                              <Label text="Printer" GridPane.halignment="RIGHT" GridPane.rowIndex="7" />
                              <Button fx:id="saveButton" maxWidth="80.0" mnemonicParsing="false" onAction="#onSaveButtonClick" text="Save" GridPane.columnIndex="1" GridPane.rowIndex="12" />
                              <Button fx:id="cancelButton" maxWidth="80.0" mnemonicParsing="false" onAction="#onCancelButtonClick" text="Cancel" GridPane.columnIndex="2" GridPane.rowIndex="12" />
                           </children>
                        </GridPane>
                        <AnchorPane prefHeight="50.0" />
