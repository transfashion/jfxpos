// root-project/build.gradle
plugins {
    id 'org.openjfx.javafxplugin' version '0.0.14' apply false
}

allprojects {
    repositories {
        mavenCentral()
    }
}

subprojects {
    apply plugin: 'java'
    
    java {
        toolchain {
            languageVersion = JavaLanguageVersion.of(21)
        }
    }

    // Redirect all JAR outputs to root project's build/libs
    tasks.withType(Jar) {
        destinationDirectory = file("${rootProject.projectDir}/build/libs")
    }
}

task run(dependsOn: ':launcher:run')





/*
 * ==========================
 * DIST FOLDER
 * ==========================
 */

tasks.register("prepareDist", Copy) {
    // dependsOn subprojects.collect { it.tasks.named("build") }

    // from("$rootDir/build/libs/launcher.jar")
    // from("$rootDir/build/libs/jfxpos.jar")

    // into("$buildDir/dist")


	dependsOn(":launcher:jar", ":jfxpos:jar")

	from("$rootDir/build/libs/launcher.jar")
    from("$rootDir/build/libs/jfxpos.jar")

    into("$buildDir/dist/app")
}


/*
 * ==========================
 * CREATE RUNTIME (JLINK)
 * ==========================
 */

tasks.register("createRuntime", Exec) {
    dependsOn prepareDist

 	def launcherProject = project(":launcher")

    def javafxModules = launcherProject.configurations.runtimeClasspath
        .filter { it.name.contains("javafx") }
        .collect { it.absolutePath }
        .join(File.pathSeparator)

    commandLine(
        "jlink",
        "--module-path", javafxModules,
        "--add-modules", "java.base,java.desktop,java.logging,javafx.controls,javafx.fxml",
        "--output", "$buildDir/runtime",
        "--strip-debug",
        "--compress", "2",
        "--no-header-files",
        "--no-man-pages"
    )

    // dependsOn prepareDist

    // commandLine(
    //     "jpackage",
    //     "--type", "app-image",
    //     "--name", "jfxpos",
    //     "--input", "$buildDir/dist/app",
    //     "--main-jar", "launcher.jar",
    //     "--main-class", "launcher.Launcher",
    //     "--dest", "$buildDir/dist"
    // )
}


/*
 * ==========================
 * BUILD EXE (JPACKAGE)
 * ==========================
 */

tasks.register("buildExe", Exec) {
    // dependsOn createRuntime

    // commandLine(
    //     "jpackage",
    //     "--type", "exe",
    //     "--name", "JFXPOS",
    //     "--input", "$buildDir/dist",
    //     "--main-jar", "launcher.jar",
    //     "--main-class", "launcher.Launcher",
    //     "--runtime-image", "$buildDir/runtime",
    //     "--dest", "$buildDir/installer",
    //     "--win-console"
    // )

	dependsOn prepareDist

    commandLine(
        "jpackage",
        "--type", "app-image",
        "--name", "jfxpos",
        "--input", "$buildDir/dist/app",
        "--main-jar", "launcher.jar",
        "--main-class", "launcher.Launcher",
        "--dest", "$buildDir/dist",
		"--win-console"
    )
}


/*
 * ==========================
 * RELEASE TASK
 * ==========================
 */

tasks.register("release") {
    dependsOn buildExe
}