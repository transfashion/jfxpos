                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                          </rowConstraints>
                           <children>
                              <Label text="Token" GridPane.halignment="RIGHT" />
                              <TextField fx:id="txtToken" GridPane.columnIndex="1" GridPane.columnSpan="6" />
                              <Button fx:id="parseButton" mnemonicParsing="false" onAction="#onParseButtonClick" prefWidth="80.0" text="Parse" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                              <TextField fx:id="txtServerUrl" GridPane.columnIndex="1" GridPane.columnSpan="6" GridPane.rowIndex="3" />
                              <Label text="Server URL" GridPane.halignment="RIGHT" GridPane.rowIndex="3" />
                              <Label text="Site ID" GridPane.halignment="RIGHT" GridPane.rowIndex="4" />
                              <Label text="Secret" GridPane.columnIndex="3" GridPane.halignment="RIGHT" GridPane.rowIndex="4" />
                              <TextField fx:id="txtSiteId" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="4" />
                              <TextField fx:id="txtKey" GridPane.columnIndex="4" GridPane.columnSpan="3" GridPane.rowIndex="4" />
                              <TextField fx:id="txtMachineId" GridPane.columnIndex="1" GridPane.rowIndex="5" />
